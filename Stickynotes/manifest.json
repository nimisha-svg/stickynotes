{
  "manifest_version": 3,
  "name": "Sticky Notes Side Panel",
  "version": "1.0.0",
  "description": "A beautiful side panel sticky notes app.",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "action": {
    "default_title": "Open Sticky Notes",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}